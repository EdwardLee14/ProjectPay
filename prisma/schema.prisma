generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CONTRACTOR
  CLIENT
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETE
}

enum ChangeOrderStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String   @id @default(cuid())
  supabaseId       String   @unique
  role             Role
  name             String
  email            String   @unique
  stripeAccountId  String?
  createdAt        DateTime @default(now())

  contractorProjects Project[] @relation("ContractorProjects")
  clientProjects     Project[] @relation("ClientProjects")
  changeOrders       ChangeOrder[]

  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  name         String
  status       ProjectStatus @default(DRAFT)
  contractorId String
  clientId     String?
  totalBudget  Float
  fundedAmount Float         @default(0)
  stripeCardId String?
  createdAt    DateTime      @default(now())

  contractor     User             @relation("ContractorProjects", fields: [contractorId], references: [id])
  client         User?            @relation("ClientProjects", fields: [clientId], references: [id])
  budgetCategories BudgetCategory[]
  transactions   Transaction[]
  changeOrders   ChangeOrder[]

  @@map("projects")
}

model BudgetCategory {
  id              String  @id @default(cuid())
  projectId       String
  name            String
  allocatedAmount Float
  spentAmount     Float   @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("budget_categories")
}

model Transaction {
  id                  String   @id @default(cuid())
  projectId           String
  merchantName        String
  amount              Float
  categoryCode        String
  note                String?
  receiptUrl          String?
  stripeTransactionId String   @unique
  createdAt           DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model ChangeOrder {
  id          String            @id @default(cuid())
  projectId   String
  requestedBy String
  amount      Float
  reason      String
  status      ChangeOrderStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requester User    @relation(fields: [requestedBy], references: [id])

  @@map("change_orders")
}
