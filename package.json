{
  "name": "projectpay",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=web",
    "db:generate": "turbo db:generate --filter=@projectpay/db",
    "db:migrate": "turbo db:migrate --filter=@projectpay/db",
    "db:push": "turbo db:push --filter=@projectpay/db"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.33.0"
}
