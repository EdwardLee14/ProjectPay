generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CONTRACTOR
  CLIENT
}

enum ProjectStatus {
  DRAFT
  PENDING_APPROVAL
  COUNTER_PROPOSED
  PENDING_FUNDING
  ACTIVE
  COMPLETE
  CANCELLED
}

enum ChangeOrderStatus {
  PENDING
  APPROVED
  REJECTED
  COUNTERED
}

enum TopUpRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AlertType {
  CATEGORY_90_PCT
  CATEGORY_100_PCT
  PROJECT_90_PCT
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  supabaseId         String   @unique
  role               Role
  name               String
  email              String   @unique
  phone              String?
  companyName        String?
  stripeAccountId    String?
  stripeCardholderId String?
  createdAt          DateTime @default(now())

  contractorProjects Project[]          @relation("ContractorProjects")
  clientProjects     Project[]          @relation("ClientProjects")
  changeOrders       ChangeOrder[]
  topUpRequests      TopUpRequest[]
  receipts           Receipt[]
  deviceTokens       DeviceToken[]
  sentProjectMessages ProjectMessage[]

  @@map("users")
}

model Project {
  id                   String        @id @default(cuid())
  name                 String
  description          String?
  status               ProjectStatus @default(DRAFT)
  contractorId         String
  clientId             String?
  clientEmail          String?
  totalBudget          Decimal       @db.Decimal(12, 2)
  fundedAmount         Decimal       @default(0) @db.Decimal(12, 2)
  stripeCardId         String?
  stripePaymentIntentId String?
  counterBudget        Decimal?  @db.Decimal(12, 2)
  closedAt             DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @default(now()) @updatedAt

  contractor       User               @relation("ContractorProjects", fields: [contractorId], references: [id])
  client           User?              @relation("ClientProjects", fields: [clientId], references: [id])
  budgetCategories BudgetCategory[]
  transactions     Transaction[]
  changeOrders     ChangeOrder[]
  accessTokens     ClientAccessToken[]
  topUpRequests    TopUpRequest[]
  budgetAlerts     BudgetAlert[]
  summary          ProjectSummary?
  messages         ProjectMessage[]

  @@index([contractorId])
  @@index([clientId])
  @@index([status])
  @@map("projects")
}

model BudgetCategory {
  id                    String   @id @default(cuid())
  projectId             String
  name                  String
  allocatedAmount       Decimal  @db.Decimal(12, 2)
  spentAmount           Decimal  @default(0) @db.Decimal(12, 2)
  merchantCategoryCodes String[] @default([])

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  topUpRequests TopUpRequest[]
  budgetAlerts  BudgetAlert[]
  changeOrders  ChangeOrder[]

  @@index([projectId])
  @@map("budget_categories")
}

model Transaction {
  id                   String   @id @default(cuid())
  projectId            String
  budgetCategoryId     String?
  merchantName         String
  amount               Decimal  @db.Decimal(12, 2)
  categoryCode         String
  status               String   @default("completed")
  note                 String?
  stripeTransactionId  String   @unique
  stripeAuthorizationId String?
  createdAt            DateTime @default(now())

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetCategory BudgetCategory? @relation(fields: [budgetCategoryId], references: [id])
  receipts       Receipt[]

  @@index([projectId, createdAt])
  @@index([budgetCategoryId])
  @@map("transactions")
}

model ChangeOrder {
  id               String            @id @default(cuid())
  projectId        String
  budgetCategoryId String?
  requestedBy      String
  amount           Decimal           @db.Decimal(12, 2)
  reason           String
  status           ChangeOrderStatus @default(PENDING)
  createdAt        DateTime          @default(now())
  resolvedAt       DateTime?

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetCategory BudgetCategory? @relation(fields: [budgetCategoryId], references: [id])
  requester      User            @relation(fields: [requestedBy], references: [id])

  @@index([projectId])
  @@map("change_orders")
}

model ClientAccessToken {
  id         String    @id @default(cuid())
  projectId  String
  token      String    @unique
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([projectId])
  @@map("client_access_tokens")
}

model Receipt {
  id            String   @id @default(cuid())
  transactionId String
  storagePath   String
  fileName      String
  mimeType      String
  uploadedBy    String
  parsedData    Json?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  uploader    User        @relation(fields: [uploadedBy], references: [id])

  @@index([transactionId])
  @@map("receipts")
}

model TopUpRequest {
  id               String             @id @default(cuid())
  projectId        String
  budgetCategoryId String
  requestedAmount  Decimal            @db.Decimal(12, 2)
  reason           String
  status           TopUpRequestStatus @default(PENDING)
  requestedBy      String
  createdAt        DateTime           @default(now())
  resolvedAt       DateTime?

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetCategory BudgetCategory @relation(fields: [budgetCategoryId], references: [id])
  requester      User           @relation(fields: [requestedBy], references: [id])

  @@index([projectId])
  @@map("top_up_requests")
}

model BudgetAlert {
  id               String    @id @default(cuid())
  projectId        String
  budgetCategoryId String?
  alertType        AlertType
  triggeredAt      DateTime  @default(now())
  acknowledgedAt   DateTime?

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetCategory BudgetCategory? @relation(fields: [budgetCategoryId], references: [id])

  @@index([projectId])
  @@map("budget_alerts")
}

model ProjectSummary {
  id                String   @id @default(cuid())
  projectId         String   @unique
  pdfStoragePath    String
  totalSpent        Decimal  @db.Decimal(12, 2)
  totalBudget       Decimal  @db.Decimal(12, 2)
  categoryBreakdown Json
  transactionCount  Int
  generatedAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@map("project_summaries")
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model ProjectMessage {
  id        String   @id @default(cuid())
  projectId String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_messages")
}
